# Server access — shared family password for HTTP Basic Auth
DASHBOARD_USERNAME=family
DASHBOARD_PASSWORD=changeme

# OpenWeatherMap API key (free tier at openweathermap.org)
OPENWEATHER_API_KEY=

# Location
LOCATION_ZIP=
LOCATION_TIMEZONE=America/New_York

# CalDAV accounts — repeat this block for each account, numbered 1..N
# PROVIDER: google | apple | outlook | generic
# PASSWORD: Google App Password (not your Google account password)

CALDAV_1_LABEL=
CALDAV_1_PROVIDER=google
CALDAV_1_USERNAME=
CALDAV_1_PASSWORD=
CALDAV_1_COLOR="#4285f4"

CALDAV_2_LABEL=
CALDAV_2_PROVIDER=google
CALDAV_2_USERNAME=
CALDAV_2_PASSWORD=
CALDAV_2_COLOR="#ea4335"

CALDAV_3_LABEL=
CALDAV_3_PROVIDER=google
CALDAV_3_USERNAME=
CALDAV_3_PASSWORD=
CALDAV_3_COLOR="#34a853"
